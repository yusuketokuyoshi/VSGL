BasedOnStyle: LLVM
Language: Cpp
IndentWidth: 4
TabWidth: 4
UseTab: AlignWithSpaces
ColumnLimit: 0
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
BreakBeforeBraces: Custom
BraceWrapping:
 AfterCaseLabel: true
 AfterClass: true
 AfterControlStatement: Always
 AfterEnum: true
 AfterFunction: true
 AfterNamespace: true
 AfterStruct: true
 AfterUnion: true
 AfterExternBlock: true
 BeforeCatch: true
 BeforeElse: true
 BeforeLambdaBody: false
 BeforeWhile: true
PointerAlignment: Left
QualifierAlignment: Left
SortIncludes: CaseSensitive
IncludeBlocks: Preserve
IncludeCategories:
 - Regex: '^"(.*)\.(h|hpp|hxx)"$'
   Priority: 1
 - Regex: '^"([^.]*)\.([^.]*)"$'
   Priority: 2
 - Regex: '^<([^.]*)\/([^.]*)>'
   Priority: 3
 - Regex: '^<([^.]*)>$'
   Priority: 4
